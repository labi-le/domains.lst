#!/bin/sh /etc/rc.common

START=99
FAKEIP_SUBNET="198.18.1.0/24"
TPROXY_NFT_FILE="/etc/nftables.d/99-tproxy.nft"

start() {
  mkdir -p /tmp/mihomo/rules
  _write_tproxy_rules
  _process_rule_set "vpn" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Categories/geoblock.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/google_ai.lst" \
    "https://raw.githubusercontent.com/labi-le/domains.lst/refs/heads/main/custom-set.txt"
  _process_rule_set "warp" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Categories/block.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Categories/porn.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Categories/anime.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Categories/news.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/twitter.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/telegram.lst" \
    "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/meta.lst" \
    "https://raw.githubusercontent.com/labi-le/domains.lst/refs/heads/main/custom-set_cis.txt"
  nft flush set inet fw4 warp_domains 2> /dev/null || true
  _process_ip_set "warp_domains" "https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Subnets/IPv4/telegram.lst"
  _process_ip_set "warp_domains" "https://raw.githubusercontent.com/routir/unblock/refs/heads/main/services/viber-ip-de.lst"
  echo "Restarting mihomo..." >&2
  /etc/init.d/mihomo restart
  exit 0
}

_write_tproxy_rules() {
  mkdir -p "$(dirname "$TPROXY_NFT_FILE")"
  cat > "$TPROXY_NFT_FILE" <<EOF
chain prerouting_tproxy {
	type filter hook prerouting priority mangle; policy accept;

	ip daddr $FAKEIP_SUBNET meta mark set 0x1
	ip daddr $FAKEIP_SUBNET meta l4proto { tcp, udp } tproxy ip to :12342 accept
}
EOF
  echo "Wrote $TPROXY_NFT_FILE for fake-IP subnet $FAKEIP_SUBNET" >&2
}

_process_rule_set() {
  local list_name="$1"
  shift
  local downloaded=""
  local output="/tmp/mihomo/rules/${list_name}.txt"
  echo "Processing $list_name rule_set..." >&2
  for url in "$@"; do
    local data=""
    for i in $(seq 1 5); do
      data=$(curl --connect-timeout 5 --max-time 15 -sSLf "$url") && break
      echo "  - Retry $i/5: $url" >&2
      sleep 3
    done
    downloaded="${downloaded}${data}\n"
  done
  printf "%b" "$downloaded" | tr -d '\r' | awk 'NF>0 && !/^#/{print $1}' | sed 's#^\.##' | sort -u | awk 'NF>0 {print "DOMAIN-SUFFIX," $1}' > "$output"
  echo "Wrote $(wc -l < "$output") entries to $output" >&2
}

_process_ip_set() {
  local set_name="$1"
  local url="$2"
  echo "Processing IP set $set_name from $url..." >&2
  local data=""
  for i in $(seq 1 5); do
    data=$(curl --connect-timeout 5 --max-time 15 -sSLf "$url") && break
    sleep 3
  done
  [ -z "$data" ] && return
  local ips
  ips=$(echo "$data" | tr -d '\r' | grep -v ':' | awk 'NF>0{printf "%s,",$1}' | sed 's/,$//')
  [ -n "$ips" ] && nft add element inet fw4 "$set_name" { $ips } 2> /dev/null
}
